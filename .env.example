# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mapbox (for address map widget)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# AWS Rekognition (for image analysis)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name

# ============================================================================
# Marketplace Providers
# ============================================================================

# Floristone (Flowers & Gifts)
# Get credentials from: https://www.floristone.com/api/
FLORISTONE_API_KEY=your-floristone-api-key
FLORISTONE_API_PASSWORD=your-floristone-api-password

# Prodigi (Print-on-Demand & Fulfillment)
# API docs: https://www.prodigi.com/print-api/docs/
# Get API key from: https://dashboard.prodigi.com/settings/api
# Sandbox: api.sandbox.prodigi.com | Production: api.prodigi.com
PRODIGI_API_KEY=your-prodigi-api-key
PRODIGI_SANDBOX=true

# Spocket (Dropshipping from US/EU Suppliers)
# Modern REST API with fast shipping
# Get API key from: https://www.spocket.co/account/settings
SPOCKET_API_KEY=your-spocket-api-key

# Goody Commerce API (Gifts & Physical Products Marketplace)
# Docs: https://developer.ongoody.com/commerce-api/overview
# Sandbox: https://sandbox.ongoody.com/business/signup
# Production: https://www.ongoody.com/business/signup
# Get API key from: Organization → Commerce API → New API Key
GOODY_COMMERCE_API_KEY=your-goody-commerce-api-key
GOODY_COMMERCE_SANDBOX=true

# ============================================================================
# Voice & AI Providers
# ============================================================================

# ElevenLabs (Voice Cloning & TTS) - REQUIRED for voice clone feature
# Get API key from: https://elevenlabs.io/app/settings/api-keys
# Plans: Free tier has 10k chars/month, Starter ($5/mo) has 30k chars
# Voice cloning requires Creator plan ($22/mo) or higher for Instant Voice Cloning
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Deepgram (Speech-to-Text & TTS fallback)
# Get API key from: https://console.deepgram.com/
DEEPGRAM_API_KEY=your-deepgram-api-key

# Anthropic Claude (AI Chat)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini (Embeddings)
GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# Security & Webhooks
# ============================================================================

# Internal API Key (for server-to-server calls)
INTERNAL_API_KEY=your-internal-api-key

# Admin Secret (for admin panel access)
ADMIN_SECRET=your-admin-secret

# Cron Secret (for scheduled job authentication)
CRON_SECRET=your-cron-secret

# Telnyx SMS Webhooks
# Get public key from: https://portal.telnyx.com/#/app/messaging/webhook-security
TELNYX_PUBLIC_KEY=your-telnyx-public-key

# Goody Webhook Secret (from Goody Commerce dashboard)
GOODY_WEBHOOK_SECRET=whsec_your-goody-webhook-secret

# ============================================================================
# Email & Payments
# ============================================================================

# Resend (Transactional Email)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourstruly.love

# Stripe (Payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx
